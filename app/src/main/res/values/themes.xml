<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PrintIt" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/caicon_blue_primary</item>
        <item name="colorPrimaryVariant">@color/caicon_blue_primary</item>

        <item name="android:statusBarColor">@color/caicon_blue_primary</item>
        <item name="android:windowSplashScreenBackground">@color/caicon_blue_primary</item>

        <item name="android:windowBackground">@color/caicon_blue_primary</item>
    </style>

    <style name="Theme.PrintIt" parent="Base.Theme.PrintIt" />
    <style name="CaiconButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/caicon_blue_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>
</resources>